# ── Twitch API (required for Twitch streaming data) ──
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# ── CORS (set to your Vercel frontend URL in production) ──
FRONTEND_URL=https://your-app.vercel.app

# ── YouTube Data API v3 (required for weekly digest) ──
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Refresh endpoint auth (required for /api/weekly-digest/refresh) ──
REFRESH_SECRET=your_random_secret_here

# ── News settings (optional) ──
NEWS_MAX_COUNT=50
NEWS_UPDATE_INTERVAL=10
